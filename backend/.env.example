# DATABASE_URL is set automatically by the CLI; uncomment for direct use:
# DATABASE_URL=file:./workspace_data/dev.db
PORT=13596
OLLAMA_URL=http://localhost:11434 #http://host.docker.internal:11434
ACTIVE_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
SUMMARY_MODEL=llama3.2
UPLOAD_DIR=./workspace_data/uploads
# ALLOWED_PATHS=./workspace_data,C:\Users\user\Desktop,/home/user

APP_URL=http://localhost:17135

# Browser automation (Playwright MCP) — by default creates an dedicated profile in workspace_data/
# To keep browser logins inside your Chrome User Data (creates a separate "AgentWorkspace" sub-profile):
#   CHROME_USER_DATA_DIR=C:\Users\<username>\AppData\Local\Google\Chrome\User Data
# Note: uses a dedicated sub-profile, does NOT conflict with your running Chrome.

# Google OAuth credentials (optional — hardcoded defaults in code)
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=

# Gemini API key (optional — used when provider.type === 'gemini')
GEMINI_API_KEY=
